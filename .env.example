# ───────────────────────────────────────────────
# Rentman API
# ───────────────────────────────────────────────
# Find your token in Rentman → Configuration → Extensions → Webshop → "show token"
RENTMAN_API_TOKEN=your-rentman-token-here

# ───────────────────────────────────────────────
# Truck Packer API
# ───────────────────────────────────────────────
# Generate a key in Truck Packer → Settings → API Keys (starts with tp_)
TRUCKPACKER_API_KEY=tp_your-api-key-here

# ───────────────────────────────────────────────
# Optional: Truck Packer folder IDs for auto-sorting
# ───────────────────────────────────────────────
# Create folders in Truck Packer UI, then paste IDs here.
# Packs auto-move to the matching folder based on Rentman status.
# TRUCKPACKER_FOLDER_ACTIVE=folder-id-for-confirmed-and-prepped
# TRUCKPACKER_FOLDER_IN_PROGRESS=folder-id-for-on-location
# TRUCKPACKER_FOLDER_COMPLETED=folder-id-for-returned
