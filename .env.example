# ───────────────────────────────────────────────
# Rentman API
# ───────────────────────────────────────────────
# Find your token in Rentman → Configuration → Extensions → Webshop → "show token"
RENTMAN_API_TOKEN=your-rentman-token-here

# ───────────────────────────────────────────────
# Truck Packer API
# ───────────────────────────────────────────────
# Generate a key in Truck Packer → Settings → API Keys (starts with tp_)
TRUCKPACKER_API_KEY=tp_your-api-key-here

# ───────────────────────────────────────────────
# Optional: Truck Packer folder IDs for auto-sorting
# ───────────────────────────────────────────────
# Create two folders in Truck Packer UI, then paste IDs here.
# New packs are sorted by project end date:
#   - End date in the future → Active folder
#   - End date in the past → Archive folder
# TRUCKPACKER_FOLDER_ACTIVE=folder-id-for-upcoming-jobs
# TRUCKPACKER_FOLDER_ARCHIVE=folder-id-for-past-jobs
